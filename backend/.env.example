# ── Database ──────────────────────────────────────────────────────────────────
MONGO_URL=mongodb://127.0.0.1:27017/urbannest

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=development

# Session secret — use a long random string in production
SESSION_SECRET=change-me-in-production

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (not needed for SSR-only)
FRONTEND_ORIGIN=http://localhost:3000

# ── AI / Search ───────────────────────────────────────────────────────────────
XAI_API_KEY=
XAI_MODEL=grok-beta

# Groq — powers the Sahayata chatbot (free tier available at console.groq.com)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ── Images ────────────────────────────────────────────────────────────────────
PEXELS_API_KEY=

# Cloudinary (optional — local uploads used when not set)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_KEY=
CLOUDINARY_SECRET=

# ── Payments ──────────────────────────────────────────────────────────────────
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# ── Email OTP ─────────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=

# ── SMS OTP (Twilio) ──────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── E2E Testing ───────────────────────────────────────────────────────────────
FCE_API_KEY=

# ── CDN / compiled frontend assets (leave blank to use local public/) ─────────
# In production set these to the CDN URLs produced by: cd frontend && npm run build
# Example: https://cdn.urbannest.in/assets/main-abc123.css
ASSET_CSS_URL=
ASSET_JS_URL=

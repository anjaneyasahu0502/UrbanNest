{
  "name": "urbannest-backend",
  "version": "2.0.0",
  "description": "UrbanNest backend — Express + EJS SSR application",
  "license": "ISC",
  "type": "commonjs",
  "main": "app.js",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "start": "node app.js",
    "dev": "node --watch app.js",
    "seed": "node init/index.js",
    "reset:users": "node scripts/resetUsers.js",
    "migrate:users": "node scripts/migrateUsers.js",
    "create:admin": "node scripts/createAdmin.js",
    "test": "jest --runInBand --forceExit",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cloudinary": "^2.10.0",
    "connect-flash": "^0.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "ejs": "^5.0.2",
    "ejs-mate": "^4.0.0",
    "express": "^5.2.1",
    "express-rate-limit": "^6.10.0",
    "express-session": "^1.19.0",
    "helmet": "^6.0.0",
    "method-override": "^3.0.0",
    "mongodb": "^7.2.0",
    "mongoose": "^9.6.2",
    "multer": "^2.1.1",
    "nodemailer": "^6.10.1",
    "passport": "^0.7.0",
    "passport-local": "^1.0.0",
    "stripe": "^22.2.0",
    "twilio": "^5.13.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "freecustom-email": "^1.0.4",
    "jest": "^29.0.0",
    "supertest": "^6.0.0"
  }
}

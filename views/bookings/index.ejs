<% layout('/layouts/boilerplate.ejs') %>
<section class="card shadow-sm p-4 mx-auto bookings-page">
  <h1 class="h3 mb-3">Your Bookings</h1>
  <% if (bookings && bookings.length) { %>
    <table class="table">
      <thead>
        <tr>
          <th>Listing</th>
          <th>Dates</th>
          <th>Price</th>
          <th>Status</th>
          <th>Action</th>
        </tr>
      </thead>
      <tbody>
        <% bookings.forEach(b => { %>
          <tr>
            <td><a href="/listings/<%= b.listing._id %>"><%= b.listing.title %></a></td>
            <td><%= new Date(b.checkIn).toLocaleDateString() %> - <%= new Date(b.checkOut).toLocaleDateString() %></td>
            <td>&#8377; <%= b.totalPrice.toLocaleString('en-IN') %></td>
            <td><%= b.paid ? 'Paid' : 'Unpaid' %></td>
            <td>
              <form method="POST" action="/bookings/<%= b._id %>?_method=DELETE" onsubmit="return confirm('Cancel this booking?');">
                <button class="btn btn-sm btn-outline-danger">Cancel</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } else { %>
    <p class="text-muted">No bookings yet.</p>
  <% } %>
</section>

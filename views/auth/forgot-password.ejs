<% layout('/layouts/boilerplate.ejs') %>
<section class="card shadow-sm p-4 mx-auto auth-page">

  <div class="text-center mb-4">
    <div class="auth-icon-circle mb-3">
      <i class="fas fa-lock-open fa-2x" style="color: #FF9933;"></i>
    </div>
    <h1 class="h3 mb-1 fw-bold">Forgot Password?</h1>
    <p class="text-muted small">Enter your registered email and we'll send you a reset code.</p>
  </div>

  <% if (error && error.length) { %>
    <div class="alert alert-danger d-flex align-items-center gap-2">
      <i class="fas fa-exclamation-circle"></i> <%= error[0] %>
    </div>
  <% } %>

  <% if (success && success.length) { %>
    <div class="alert alert-success d-flex align-items-center gap-2">
      <i class="fas fa-check-circle"></i> <%= success[0] %>
    </div>
  <% } %>

  <form action="/auth/forgot-password" method="POST">
    <div class="mb-4">
      <label class="form-label fw-semibold">
        <i class="fas fa-envelope me-1" style="color: #FF9933;"></i> Registered Email
      </label>
      <input
        name="email"
        type="email"
        class="form-control form-control-lg"
        required
        placeholder="you@example.com"
        autocomplete="email"
        style="border: 2px solid #FF9933; border-radius: 12px;"
      >
    </div>

    <button class="btn btn-urbannest w-100 btn-lg mb-3" type="submit">
      <i class="fas fa-paper-plane me-2"></i> Send Reset Code
    </button>
  </form>

  <hr>
  <p class="text-center mb-0 small">
    Remembered your password?
    <a href="/auth/login" class="fw-bold" style="color: #FF9933;">Sign In</a>
  </p>
  <p class="text-center mb-0 small mt-2">
    New here?
    <a href="/auth/register" class="fw-bold" style="color: #138808;">Sign Up</a>
  </p>
</section>

<style>
  .auth-page {
    max-width: 480px;
    margin-top: 2rem;
    margin-bottom: 2rem;
    border-radius: 1.25rem;
    border: 2px solid #FFE6CC;
  }
  .auth-icon-circle {
    width: 70px;
    height: 70px;
    border-radius: 50%;
    background: linear-gradient(135deg, #FFF5E6, #FFE6CC);
    border: 2px solid #FF9933;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .btn-urbannest {
    background: linear-gradient(135deg, #FF9933, #FF6B35);
    color: white;
    border: none;
    font-weight: 600;
    border-radius: 12px;
    transition: all 0.3s ease;
  }
  .btn-urbannest:hover {
    background: linear-gradient(135deg, #FF6B35, #FF9933);
    color: white;
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(255,153,51,0.4);
  }
</style>

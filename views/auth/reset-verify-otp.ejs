<% layout('/layouts/boilerplate.ejs') %>
<section class="card shadow-sm p-4 mx-auto auth-page">

  <div class="text-center mb-4">
    <div class="auth-icon-circle mb-3">
      <i class="fas fa-shield-alt fa-2x" style="color: #FF9933;"></i>
    </div>
    <h1 class="h3 mb-1 fw-bold">Enter Reset Code</h1>
    <p class="text-muted small">We've sent a 6-digit code to your registered email. Enter it below.</p>
  </div>

  <% if (error && error.length) { %>
    <div class="alert alert-danger d-flex align-items-center gap-2">
      <i class="fas fa-exclamation-circle"></i> <%= error[0] %>
    </div>
  <% } %>

  <% if (success && success.length) { %>
    <div class="alert alert-success d-flex align-items-center gap-2">
      <i class="fas fa-check-circle"></i> <%= success[0] %>
    </div>
  <% } %>

  <form action="/auth/reset-verify-otp" method="POST">
    <div class="mb-4">
      <label class="form-label fw-semibold">
        <i class="fas fa-key me-1" style="color: #FF9933;"></i> Reset Code
      </label>
      <input
        id="otpInput"
        name="emailOTP"
        class="form-control form-control-lg text-center otp-input"
        required
        pattern="[0-9]{6}"
        maxlength="6"
        placeholder="• • • • • •"
        autocomplete="one-time-code"
        inputmode="numeric"
      >
      <small class="form-text text-muted mt-1">
        <i class="fas fa-clock me-1"></i> Code expires in 10 minutes
      </small>
    </div>

    <button class="btn btn-urbannest w-100 btn-lg mb-3" type="submit">
      <i class="fas fa-check-circle me-2"></i> Verify Code
    </button>
  </form>

  <form action="/auth/reset-resend-otp" method="POST" class="text-center mb-3">
    <p class="text-muted small mb-2">Didn't receive the code?</p>
    <button class="btn btn-outline-secondary btn-sm" type="submit">
      <i class="fas fa-redo me-1"></i> Resend Code
    </button>
  </form>

  <hr>
  <p class="text-center mb-0 small">
    <a href="/auth/forgot-password" style="color: #FF9933;">
      <i class="fas fa-arrow-left me-1"></i> Back
    </a>
  </p>
</section>

<style>
  .auth-page {
    max-width: 480px;
    margin-top: 2rem;
    margin-bottom: 2rem;
    border-radius: 1.25rem;
    border: 2px solid #FFE6CC;
  }
  .auth-icon-circle {
    width: 70px;
    height: 70px;
    border-radius: 50%;
    background: linear-gradient(135deg, #FFF5E6, #FFE6CC);
    border: 2px solid #FF9933;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .otp-input {
    letter-spacing: 14px;
    font-size: 1.8rem;
    font-weight: 700;
    border: 2px solid #FF9933;
    border-radius: 12px;
    color: #FF9933;
  }
  .otp-input:focus {
    border-color: #FF6B35;
    box-shadow: 0 0 0 0.2rem rgba(255,153,51,0.25);
  }
  .btn-urbannest {
    background: linear-gradient(135deg, #FF9933, #FF6B35);
    color: white;
    border: none;
    font-weight: 600;
    border-radius: 12px;
    transition: all 0.3s ease;
  }
  .btn-urbannest:hover {
    background: linear-gradient(135deg, #FF6B35, #FF9933);
    color: white;
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(255,153,51,0.4);
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const input = document.getElementById('otpInput');
    if (!input) return;

    input.focus();

    // Only allow digits
    input.addEventListener('input', function () {
      this.value = this.value.replace(/[^0-9]/g, '').slice(0, 6);
    });

    // Handle paste
    input.addEventListener('paste', function (e) {
      e.preventDefault();
      const pasted = e.clipboardData.getData('text').replace(/[^0-9]/g, '');
      this.value = pasted.slice(0, 6);
    });
  });
</script>
